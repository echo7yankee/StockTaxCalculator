generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id              String    @id @default(uuid())
  email           String    @unique
  name            String?
  passwordHash    String?
  googleId        String?   @unique
  plan            String    @default("free")
  planPurchasedAt DateTime?
  planExpiresAt   DateTime?
  stripeCustomerId      String? @unique
  stripePaymentIntentId String?
  launchPriceUsed Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  taxYears            TaxYear[]
  passwordResetTokens PasswordResetToken[]
  parseAlertLogs      ParseAlertLog[]
}

model PromoCounter {
  id    String @id @default("launch_2026")
  count Int    @default(0)
  limit Int    @default(100)
}

model WebhookEvent {
  id          String   @id
  eventName   String
  processedAt DateTime @default(now())
  payload     String
}

model Session {
  id        String   @id
  sid       String   @unique
  data      String
  expiresAt DateTime
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([token])
  @@index([userId])
}

model TaxYear {
  id          String       @id @default(uuid())
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  year        Int
  country     String       @default("RO")
  status      String       @default("draft")
  createdAt   DateTime     @default(now())
  csvUploads  CsvUpload[]
  transactions Transaction[]
  calculation TaxCalculation?

  @@unique([userId, year])
  @@index([userId])
}

model CsvUpload {
  id           String        @id @default(uuid())
  taxYearId    String
  taxYear      TaxYear       @relation(fields: [taxYearId], references: [id], onDelete: Cascade)
  broker       String
  filename     String?
  uploadedAt   DateTime      @default(now())
  processed    Boolean       @default(false)
  rowCount     Int?
  transactions Transaction[]

  @@index([taxYearId])
}

model Transaction {
  id                     String   @id @default(uuid())
  csvUploadId            String
  csvUpload              CsvUpload @relation(fields: [csvUploadId], references: [id], onDelete: Cascade)
  taxYearId              String
  taxYear                TaxYear  @relation(fields: [taxYearId], references: [id], onDelete: Cascade)
  action                 String
  transactionDate        DateTime
  isin                   String?
  ticker                 String?
  securityName           String?
  shares                 Float?
  pricePerShare          Float?
  priceCurrency          String?
  totalAmountOriginal    Float?
  exchangeRateToLocal    Float?
  totalAmountLocal       Float?
  withholdingTaxOriginal Float?
  withholdingTaxCurrency String?
  withholdingTaxLocal    Float?
  brokerTransactionId    String?
  createdAt              DateTime @default(now())

  @@index([taxYearId])
  @@index([csvUploadId])
}

model BnrRate {
  id       Int      @id @default(autoincrement())
  rateDate DateTime
  currency String
  rate     Float

  @@unique([rateDate, currency])
}

model TaxCalculation {
  id                     String   @id @default(uuid())
  taxYearId              String   @unique
  taxYear                TaxYear  @relation(fields: [taxYearId], references: [id], onDelete: Cascade)
  totalCapitalGains      Float?
  totalCapitalLosses     Float?
  netCapitalGains        Float?
  capitalGainsTax        Float?
  totalDividendsGross    Float?
  totalWithholdingTax    Float?
  dividendTaxOwed        Float?
  totalNonSalaryIncome   Float?
  cassOwed               Float?
  cassThresholdHit       String?
  totalTaxOwed           Float?
  earlyFilingDiscount    Float?
  calculatedAt           DateTime @default(now())
  securities             SecurityCalculation[]
}

model SecurityCalculation {
  id                 String         @id @default(uuid())
  taxCalculationId   String
  taxCalculation     TaxCalculation @relation(fields: [taxCalculationId], references: [id], onDelete: Cascade)
  isin               String?
  ticker             String?
  securityName       String?
  totalBoughtShares  Float?
  totalSoldShares    Float?
  remainingShares    Float?
  weightedAvgCost    Float?
  totalProceeds      Float?
  totalCostBasis     Float?
  realizedGainLoss   Float?
  totalDividends     Float?
  totalWithholdingTax Float?
}

model ParseAlertLog {
  id                String   @id @default(uuid())
  userId            String?
  user              User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  parsedAt          DateTime @default(now())
  fileType          String
  fileName          String?
  taxYear           Int?
  outcome           String
  parserWarnings    Json
  engineWarnings    Json
  errorMessage      String?
  sellCount         Int?
  dividendCount     Int?
  distributionCount Int?
  pageCount         Int?

  @@index([parsedAt])
  @@index([userId, parsedAt])
  @@index([outcome])
}

// Off-season audience capture. Anonymous (no User FK): a visitor can subscribe
// to a filing reminder or a broker-graduation waitlist without an account.
// Double opt-in: a row is created pending (confirmedAt null, confirmToken set),
// and only confirmed rows with unsubscribedAt null are eligible to be emailed.
// A person can hold one row per topic (e.g. filing_reminder + broker_revolut).
model EmailSubscriber {
  id             String    @id @default(uuid())
  email          String
  topic          String
  language       String    @default("ro")
  source         String?
  confirmToken   String?   @unique
  confirmedAt    DateTime?
  unsubToken     String    @unique
  unsubscribedAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([email, topic])
  @@index([topic])
}

// First-party, cookieless analytics. Replaces the third-party Plausible script
// (removed from client/index.html). One row per event: a 'pageview' or a named
// funnel event (paywall_seen, checkout_started, ...). Deliberately stores NO
// PII, NO IP, NO user-agent, NO cookie or visitor id; only the event name, the
// pathname, and the referrer HOST (for channel attribution). Read via the
// analytics-report CLI (server/src/scripts/analytics-report.ts).
model AnalyticsEvent {
  id        String   @id @default(uuid())
  name      String
  path      String?
  referrer  String?
  createdAt DateTime @default(now())

  @@index([name, createdAt])
  @@index([createdAt])
}

// First-party error monitoring (replaces the inert third-party Sentry wiring).
// One row per distinct error "issue", keyed by a fingerprint (error name +
// normalized message + top stack frame), so repeated occurrences increment a
// counter and bump lastSeen instead of flooding the table with one row per hit.
// Stored PII-scrubbed: the message is normalized (ids/numbers/urls masked) and
// the sample stack is scrubbed (query strings + emails removed) + truncated.
// v1 captures SERVER errors (the Express error handler + uncaughtException /
// unhandledRejection process handlers); the client beacon (source='client') is
// a follow-up. Read via the errors-report CLI (npm run errors -w server).
model ErrorEvent {
  id          String   @id @default(uuid())
  fingerprint String   @unique
  source      String   @default("server")
  name        String
  message     String
  sampleStack String?
  context     String?
  count       Int      @default(1)
  firstSeen   DateTime @default(now())
  lastSeen    DateTime @default(now())

  @@index([lastSeen])
  @@index([source, lastSeen])
}
