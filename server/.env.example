SESSION_SECRET=generate-a-random-string-here
CLIENT_URL=http://localhost:5173
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

# Analytics & Monitoring (Section 4)
SENTRY_DSN=
VITE_SENTRY_DSN=

# Payment processor selection (Section 2)
# Values: "lemon" (default, Lemon Squeezy) or "stripe" (Stripe direct)
# Switching providers requires the matching credentials below to be set.
PAYMENT_PROVIDER=lemon

# Lemon Squeezy Payment (Section 2 — primary, in use)
LEMON_SQUEEZY_STORE_ID=
LEMON_SQUEEZY_VARIANT_ID=
LEMON_SQUEEZY_API_KEY=
LEMON_SQUEEZY_WEBHOOK_SECRET=

# Stripe Payment (Section 2 — parallel track, activated by PAYMENT_PROVIDER=stripe)
# STRIPE_PRICE_ID: the Stripe price object ID for the €19 annual product (e.g. price_...)
# STRIPE_LAUNCH_COUPON_ID: Stripe coupon ID for the -€7 launch discount, optional
# STRIPE_WEBHOOK_SECRET: starts with whsec_
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=
STRIPE_LAUNCH_COUPON_ID=
